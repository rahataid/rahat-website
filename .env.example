# Base URL for the Impact API/backend
NEXT_PUBLIC_IMPACT_HOST=
# Base URL for the Community API/backend
NEXT_PUBLIC_COMMUNITY_HOST=
# Host URL for uploading assets (images, files, etc.)
NEXT_PUBLIC_UPLOAD_ASSET_HOST=
# Root folder name in AWS S3 for asset storage
NEXT_PUBLIC_AWS_ROOT_FOLDER_NAME=

# Host URL for viewing assets (public asset CDN or S3 bucket)
NEXT_PUBLIC_ASSET_VIEW_HOST=
# Folder path for viewing assets (within the asset view host)
NEXT_PUBLIC_ASSET_VIEW_FOLDER=
# Mapbox API access token for map features
NEXT_PUBLIC_MAPBOX_TOKEN=
# SMTP username for sending emails (contact forms, notifications)
NEXT_PUBLIC_SMTP_USER=
# SMTP password for sending emails
NEXT_PUBLIC_SMTP_PASS=
# Base URL for the CMS API (content management)
NEXT_PUBLIC_CMS_API=